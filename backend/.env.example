# Variables de app/config.py. Copiar a .env y rellenar.
# Ningún valor real vive en el repositorio.

# --- infraestructura -------------------------------------------------------
# Con docker-compose, este valor ya lo inyecta el propio compose.
DATABASE_URL=postgresql://xframe:xframe@localhost:5432/xframe
REDIS_URL=redis://localhost:6379/0

SUPABASE_URL=
# Clave de servicio: salta RLS. El backend filtra por project_id a mano en cada
# consulta, así que esta clave nunca debe salir del servidor.
# Debe ser el JWT `service_role` (empieza por eyJ...), NO la clave `sb_secret_...`
# del panel nuevo: esa lista buckets pero el endpoint de subida la rechaza con
# 'Invalid Compact JWS', y el job muere despues de haberse pagado la generacion.
SUPABASE_SERVICE_KEY=
STORAGE_BUCKET=xframe-assets

# --- autenticación ---------------------------------------------------------
# El user_id sale SIEMPRE de claims["sub"] de un JWT verificado; nunca de una
# cabecera. Las claves públicas se leen de
# {SUPABASE_URL}/auth/v1/.well-known/jwks.json y no hay que configurarlas.
#
# Solo para proyectos que sigan en el modo HS256 legacy. Déjalo VACÍO si tu
# proyecto ya firma con ES256: vacío significa "rechaza los tokens HS256", que
# es lo que cierra la confusión de algoritmo.
SUPABASE_JWT_SECRET=
# Vacío = se deriva de SUPABASE_URL. Solo con un gateway por delante.
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated
JWKS_CACHE_TTL_S=600
JWT_LEEWAY_S=10

# Ticket de un solo uso para el SSE de reenganche: el EventSource del navegador
# no puede mandar cabeceras. Corto a propósito, solo tiene que durar lo que
# tarda en abrirse la conexión.
SSE_TICKET_TTL_S=60

# URLs firmadas del bucket. Tiene que cubrir la COLA del proveedor además del
# render: se le pasa la URL al enviar el job y la descarga cuando le toca.
SIGNED_URL_TTL_S=3600

# --- límites de petición ---------------------------------------------------
# Turnos por ventana y usuario en /chat. 0 desactiva el limitador.
CHAT_RATE_LIMIT=20
CHAT_RATE_LIMIT_WINDOW_S=60

# --- LLM -------------------------------------------------------------------
ANTHROPIC_API_KEY=

# Defectos, no un router: cada tarea elige su modelo junto a su código.
# Quien razona: 'openai' o 'anthropic'. Lo construye app/llm.py, un unico sitio.
LLM_PROVIDER=openai

# Verificados contra developers.openai.com/api/docs/models el 2026-07-20.
# Familia GPT-5.6: sol (frontera), terra (equilibrado), luna (barato).
MODEL_ROOT=gpt-5.6-sol
MODEL_FAST=gpt-5.6-luna
MODEL_SUMMARIZE=gpt-5.6-luna

# --- proveedores de generación --------------------------------------------
# Solo hacen falta los de los modelos que estén 'active' en gen_models.
GOOGLE_API_KEY=
# Una sola clave sirve para las DOS familias de OpenAI, que son proveedores distintos
# para el registry: 'openai' (Sora 2, video) y 'openai_image' (GPT Image). Si es la unica
# clave que tienes, con ella ya puedes crear elements —personajes, localizaciones,
# objetos— y probar la continuidad de personaje, que es el flujo central del producto.
OPENAI_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
MINIMAX_API_KEY=
BYTEDANCE_API_KEY=
WAN_API_KEY=
HIGGSFIELD_KEY_ID=
HIGGSFIELD_KEY_SECRET=
BFL_API_KEY=

# Base de los webhooks de proveedor. Debe ser alcanzable desde internet: en local,
# un túnel (ngrok, cloudflared). Si esto apunta a localhost, los jobs solo terminan
# por polling y se tarda más en verlo.
PUBLIC_BASE_URL=http://localhost:8000

# --- webhooks de proveedor -------------------------------------------------
# La ruta es POST /webhooks/{proveedor} y es PUBLICA: el proveedor llama desde su
# infraestructura y no tiene el JWT del usuario. Lo que autentica la entrega es la
# firma del cuerpo, no una sesion.
#
# Secretos de firma, formato `proveedor=secreto,proveedor=secreto`. Higgsfield y
# Kling no hacen falta aqui: se derivan de sus credenciales de arriba.
# SIN secreto configurado el webhook NO decide nada por si solo: se ignora el
# cuerpo y se reconsulta el estado con poll(). Es mas lento y es lo correcto,
# porque un cuerpo sin firmar lo ha escrito quien sea y aqui se mueve dinero.
WEBHOOK_SECRETS=

# BFL es el unico que acepta el secreto en el propio submit (`webhook_secret`) y
# firma con el. Con esto puesto, sus entregas si son fuente de verdad.
BFL_WEBHOOK_SECRET=

# Token opaco que viaja en la URL de callback (?t=...) y que el endpoint exige si
# esta configurado. No sustituye a la firma; cierra el hueco de los proveedores que
# no firman, evitando que un tercero pida que releamos jobs ajenos.
# OJO: activarlo obliga a re-registrar las URLs ya dadas de alta en los proveedores.
WEBHOOK_PATH_TOKEN=

# --- descarga de salidas ---------------------------------------------------
# Dominios EXTRA desde los que se acepta descargar el binario de un job, separados
# por comas. La lista normal la declara cada adaptador en `output_domains`; esto es
# la valvula de escape para cuando un proveedor rota su CDN y no da tiempo a
# desplegar. Todo lo demas (IPs privadas, loopback, link-local, ULA) se rechaza
# siempre, este o no en esta lista.
OUTPUT_HOST_ALLOWLIST=

# --- economía --------------------------------------------------------------
# Créditos por dólar de coste de API, y margen sobre ese coste. Los precios por
# modelo se derivan de aquí, así que subir el margen es cambiar una constante.
CREDITS_PER_USD=100
CREDIT_MARGIN=1.6

# --- montaje ---------------------------------------------------------------
# ffprobe se deriva de esta ruta; no hay variable propia.
FFMPEG_PATH=ffmpeg

# --- evals (opcional, solo desarrollo) -------------------------------------
# Juez de los scorers LLM. Cambiarlo invalida la comparación con ejecuciones previas.
EVAL_JUDGE_MODEL=
EVAL_CONCURRENCY=8
EVAL_CASE_TIMEOUT_S=480
# Opt-in explícito para las suites que renderizan de verdad y gastan créditos.
EVAL_ALLOW_RENDER=0
EVAL_PROJECT_ID=

# Origenes permitidos, separados por comas. Vacio = rango de desarrollo (5173-5182).
CORS_ORIGINS=https://xframe-tau.vercel.app
